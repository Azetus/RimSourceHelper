{
  "compilerOptions": {
    "target": "ES2022",                 // 编译后的 JavaScript 版本 (ES2022 支持现代特性)
    "module": "NodeNext",               // 模块格式，与 Node.js 的 ES 模块兼容
    "moduleResolution": "NodeNext",     // 模块解析策略，适配 NodeNext 模块系统
    "outDir": "./dist",                 // 编译输出目录
    "rootDir": "./src",                 // 源代码根目录
    "strict": true,                     // 开启所有严格的类型检查
    "esModuleInterop": true,            // 允许 import 语法导入 CommonJS 模块
    "skipLibCheck": true,               // 跳过库文件的类型检查（加快编译）
    "resolveJsonModule": true           // 允许 import JSON 文件
  },
  "include": ["src/**/*"],              // 需要编译的文件
  "exclude": ["node_modules", "dist"]   // 排除的文件夹
}
